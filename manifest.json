{
  "manifest_version": 3,
  "name": "TouchLock – Fingerprint Browser Lock",
  "version": "1.0.2",
  "description": "Lock your browser profile with Touch ID, Windows Hello, or a 6-digit PIN.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "idle"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TouchLock – Fingerprint Browser Lock",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": ["<all_urls>"]
}
